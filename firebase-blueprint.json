{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "client"] },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Grocery product details.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "price", "stock", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "items": { "type": "array" },
        "paymentMode": { "type": "string", "enum": ["UPI", "COD"] },
        "total": { "type": "number" },
        "isCompleted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "items", "total", "isCompleted"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles collection."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Products collection."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Orders collection."
    }
  }
}
